---
import RootLayout from "./RootLayout.astro";

const { pageTitle } = Astro.props;
---

<RootLayout pageTitle={pageTitle}>
  <header>
    <h3>Jorge Reyes</h3>
    <p>
      Software Engineer @ <a href="https://www.jetpacklabs.com/" class="glow"
        >Jetpack Labs</a
      >
    </p>
    <p class="quote">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="25"
        height="13"
        viewBox="0 0 35 23"
        fill="#080f0f"
      >
        <path
          d="M1 22L13.5962 3.19977C15.5766 0.243877 19.9234 0.243882 21.9039 3.19978L34.5 22"
          stroke="#1A2D2D"></path>
      </svg>
       “Sometimes even to live is an act of courage” — Seneca
    </p>
  </header>
  <slot />
</RootLayout>
